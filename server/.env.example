# Spend Smart — Server Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.

# Server port (default: 5000)
PORT=5000

# MongoDB connection string
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/spend_smart?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/spend_smart

# JWT secret key — use a strong random string in production
JWT_SECRET=your_strong_random_jwt_secret_here

# Google OAuth credentials (optional — leave placeholder values to disable)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Groq API key — get yours at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# CORS — comma-separated list of allowed frontend origins
# Development default: http://localhost:5173,http://localhost:4173
# Production example: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Node environment (development | production)
NODE_ENV=development
